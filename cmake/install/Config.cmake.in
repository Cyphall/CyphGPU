@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(glm)
find_dependency(VulkanHeaders)
find_dependency(VulkanMemoryAllocator)
find_dependency(magic_enum)
find_dependency(boost_optional)
find_dependency(spdlog)
find_dependency(Tracy)
find_dependency(CMakeRC)

include("${CMAKE_CURRENT_LIST_DIR}/CyphGPUTargets.cmake")

set_property(TARGET CyphGPU APPEND PROPERTY INTERFACE_LINK_LIBRARIES cmrc::base)

check_required_components(CyphGPU)